{
	"servers": {
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.31"
		}
	},
	{
  "mcpServers": {
    "copilot-memory-sqlite": {
      "command": "node",
      "args": [
        "/home/vscode/.vscode-remote/server/index-sqlite.js"
      ],
      "env": {},
      "description": "GitHub Copilot Memory SQLite - High-performance knowledge storage"
    }
  },
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	]
}